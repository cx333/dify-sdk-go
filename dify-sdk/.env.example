DIFY_BASE_URL=http://localhost:5001/v1
DIFY_API_KEYS=app-xxxxxxxx,app-yyyyyyyy
DIFY_TIMEOUT=30s
DIFY_MAX_RETRIES=3
# 默认用户标识。当请求未传入 user 参数时的最终兜底值。
# 安全警告：Dify 靠 "user + conversation_id" 隔离会话记忆。
# 所有请求共用同一个 user 会导致不同终端用户看到彼此的对话历史。
# 推荐做法：始终由业务代码逐请求传入真实用户 ID。
# 仅单用户内部工具或开发环境可依赖此默认值。
# DIFY_DEFAULT_USER=internal-tool
