# ---- Dify API 连接 ----
DIFY_BASE_URL=http://localhost:5001/v1
# 密钥，推荐使用编号变量；未设置时回退读取逗号分隔的 DIFY_API_KEYS
DIFY_API_KEY_0=app-xxxxxxxx
# DIFY_API_KEY_1=app-yyyyyyyy
# DIFY_API_KEYS=app-xxxxxxxx,app-yyyyyyyy
DIFY_TIMEOUT=30s
DIFY_MAX_RETRIES=3

# ---- 服务器 ----
SERVER_PORT=8080
ENV=development
METHOD_TIMEOUT=30s

# ---- 出站限流（保护 Dify 不被冲垮） ----
# OUTBOUND_RPS: 每秒允许发往 Dify 的最大请求数，0=不限
OUTBOUND_RPS=50
# OUTBOUND_BURST: 突发容量，允许瞬间超过 RPS 的请求数
OUTBOUND_BURST=10

# ---- 方法执行并发控制 ----
# MAX_CONCURRENT_METHODS: 同时执行的方法数上限，0=不限
MAX_CONCURRENT_METHODS=100

# ---- 日志 ----
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# LOG_FORMAT: text | json（生产环境建议 json）
LOG_FORMAT=text

# ---- 日志落盘 ----
# LOG_FILE_ENABLED: 是否开启日志落盘，true=写入文件，false=仅控制台
LOG_FILE_ENABLED=false
# LOG_DIR: 日志保存目录
LOG_DIR=./logs
# LOG_MAX_SIZE: 单个日志文件最大大小（MB），超过后自动轮转
LOG_MAX_SIZE=100
# LOG_MAX_AGE: 日志最大保留天数，超过后自动删除
LOG_MAX_AGE=30
# LOG_MAX_BACKUPS: 最多保留的旧日志文件数
LOG_MAX_BACKUPS=10
